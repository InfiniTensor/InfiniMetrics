[
    {
        "operator": "mul",
        "device": "nvidia",
        "description": "Mul Operator Test Suite",
        "torch_op": "torch.mul",
        "infinicore_op": "infinicore.mul",
        "args": {
            "bench": "both",
            "num_prerun": 10,
            "num_iterations": 100,
