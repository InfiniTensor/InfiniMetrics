                    },
                    {
                        "name": "b",
                        "dtype": "float32",
                        "shape": [13, 4, 4],
                        "strides": [20, 4, 1]
                    }
                ],
                "kwargs": {
                    "out": 0
                },
                "comparison_target": 0,
                "tolerance": {
                    "atol": 1e-5,
                    "rtol": 1e-3
                }
            },
            {
                "description": "Case 2: Same shape (Demonstrating multi-case list)",
                "inputs": [
                    {
                        "name": "a",
                        "dtype": "float32",
                        "shape": [13, 4, 4],
                        "strides": [20, 4, 1]
                    },
                    {
                        "name": "b",
                        "dtype": "float32",
                        "shape": [13, 4, 4],
                        "strides": [20, 4, 1]
                    }
                ],
                "kwargs": {
                    "out": 1
                },
                "comparison_target": 1,
                "tolerance": {
                    "atol": 1e-5,
